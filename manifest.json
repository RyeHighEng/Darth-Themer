{
  "manifest_version": 3,
  "name": "Web Themer",
  "description": "Apply custom themes and font overrides to websites with per-site controls.",
  "version": "1.0.0",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["theme-presets.js", "settings.js", "content-script.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Web Themer",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
