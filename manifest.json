{
  "manifest_version": 3,
  "name": "Darth Themer",
  "description": "Apply custom themes and font overrides to websites with per-site controls.",
  "version": "1.0.0",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["theme-presets.js", "settings.js", "content-script.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Darth Themer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
